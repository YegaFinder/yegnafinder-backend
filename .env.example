# ─── Application ────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
# Comma-separated list of allowed PWA origins (e.g., http://localhost:3000,https://app.yegnafinder.com)
FRONTEND_ORIGIN=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=yegnafinder

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP ─────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
