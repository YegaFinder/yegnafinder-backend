# ─── Application ────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
# Comma-separated list of allowed PWA origins
FRONTEND_ORIGIN=http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/yegnafinder

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP ─────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# ─── Social Login ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── Email Configuration (Nodemailer) ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
